# Database (pgBouncer pooled connection)
DATABASE_URL="postgresql://username:password@pgbouncer-host:6432/investment_platform?pgbouncer=true"

# Database (direct connection — required for Prisma migrations)
DIRECT_URL="postgresql://username:password@localhost:5432/investment_platform"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-here-generate-with-openssl-rand-base64-32"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Email (Resend)
RESEND_API_KEY="re_..."
EMAIL_FROM="Pooled Wealth <noreply@pooledwealth.com>"

# App
NEXT_PUBLIC_APP_URL="https://yourplatform.com"

# Cron job secret — generate with: openssl rand -base64 32
# Must match the value set in Vercel Environment Variables
CRON_SECRET="generate-with-openssl-rand-base64-32"
